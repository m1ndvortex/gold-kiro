<!-- Header Section -->
<div class="customers-header">
    <div class="header-content">
        <div class="header-text">
            <h1>🏪 مدیریت مشتریان</h1>
            <p>مشاهده، جستجو و مدیریت اطلاعات مشتریان طلافروشی</p>
        </div>
        <div class="header-actions">
            <a href="/customers/add" class="btn-primary">
                <span class="btn-icon">➕</span>
                <span class="btn-text">مشتری جدید</span>
            </a>
        </div>
    </div>
</div>

<!-- Statistics Dashboard -->
<div class="stats-dashboard">
    <div class="stat-card total">
        <div class="stat-icon">👥</div>
        <div class="stat-content">
            <div class="stat-number"><%= customers.length %></div>
            <div class="stat-label">کل مشتریان</div>
        </div>
        <div class="stat-trend">📊</div>
    </div>
    
    <div class="stat-card active">
        <div class="stat-icon">✅</div>
        <div class="stat-content">
            <div class="stat-number"><%= customers.filter(c => c.is_active).length %></div>
            <div class="stat-label">فعال</div>
        </div>
        <div class="stat-trend">🟢</div>
    </div>
    
    <div class="stat-card vip">
        <div class="stat-icon">⭐</div>
        <div class="stat-content">
            <div class="stat-number"><%= customers.filter(c => c.customer_type === 'vip').length %></div>
            <div class="stat-label">VIP</div>
        </div>
        <div class="stat-trend">👑</div>
    </div>
    
    <div class="stat-card debtor">
        <div class="stat-icon">💰</div>
        <div class="stat-content">
            <div class="stat-number"><%= customers.filter(c => c.current_balance > 0).length %></div>
            <div class="stat-label">بدهکار</div>
        </div>
        <div class="stat-trend">📈</div>
    </div>
</div>

<!-- Advanced Search & Filters -->
<div class="search-container">
    <div class="search-header">
        <h3>🔍 جستجو و فیلتر</h3>
        <button class="btn-clear" onclick="clearAllFilters()">
            <span>🗑️</span>
            پاک کردن فیلترها
        </button>
    </div>
    
    <div class="search-grid">
        <div class="search-item">
            <label>جستجو در نام مشتری</label>
            <div class="input-group">
                <span class="input-icon">👤</span>
                <input type="text" id="nameSearch" placeholder="نام مشتری را وارد کنید...">
            </div>
        </div>
        
        <div class="search-item">
            <label>جستجو شماره تماس</label>
            <div class="input-group">
                <span class="input-icon">📱</span>
                <input type="text" id="phoneSearch" placeholder="شماره تماس را وارد کنید...">
            </div>
        </div>
        
        <div class="search-item">
            <label>نوع مشتری</label>
            <div class="select-group">
                <select id="customerTypeFilter">
                    <option value="">همه</option>
                    <option value="normal">👤 عادی</option>
                    <option value="vip">⭐ VIP</option>
                    <option value="wholesale">🏢 عمده‌فروش</option>
                    <option value="regular">🔄 ثابت</option>
                </select>
            </div>
        </div>
        
        <div class="search-item">
            <label>وضعیت</label>
            <div class="select-group">
                <select id="statusFilter">
                    <option value="">همه</option>
                    <option value="active">✅ فعال</option>
                    <option value="inactive">❌ غیرفعال</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Customers Table -->
<div class="table-wrapper">
    <div class="table-header">
        <h3>📋 لیست مشتریان</h3>
        <div class="table-info">
            <span id="tableCount"><%= customers.length %></span> مشتری
        </div>
    </div>
    
    <div class="table-container">
        <table id="customersTable">
            <thead>
                <tr>
                    <th>وضعیت</th>
                    <th>کد مشتری</th>
                    <th>اطلاعات شخصی</th>
                    <th>تماس</th>
                    <th>نوع</th>
                    <th>سن</th>
                    <th>حساب مالی</th>
                    <th>آخرین خرید</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                <% if (customers && customers.length > 0) { %>
                    <% customers.forEach(customer => { %>
                        <tr class="customer-row" 
                            data-type="<%= customer.customer_type || 'normal' %>" 
                            data-status="<%= customer.is_active ? 'active' : 'inactive' %>">
                            
                            <!-- وضعیت -->
                            <td class="status-cell">
                                <div class="status-badges">
                                    <% if (customer.is_active) { %>
                                        <span class="badge active">فعال</span>
                                    <% } else { %>
                                        <span class="badge inactive">غیرفعال</span>
                                    <% } %>
                                    <% if (customer.customer_type === 'vip') { %>
                                        <span class="badge vip">VIP</span>
                                    <% } %>
                                </div>
                            </td>
                            
                            <!-- کد مشتری -->
                            <td class="code-cell">
                                <div class="customer-code">
                                    <%= customer.customer_code %>
                                </div>
                            </td>
                            
                            <!-- اطلاعات شخصی -->
                            <td class="info-cell">
                                <div class="customer-info">
                                    <div class="name"><%= customer.full_name %></div>
                                    <% if (customer.email) { %>
                                        <div class="email">📧 <%= customer.email %></div>
                                    <% } %>
                                    <% if (customer.national_id) { %>
                                        <div class="national-id">🆔 <%= customer.national_id %></div>
                                    <% } %>
                                </div>
                            </td>
                            
                            <!-- تماس -->
                            <td class="contact-cell">
                                <div class="contact-info">
                                    <% if (customer.phone) { %>
                                        <div class="phone">📱 <%= customer.phone %></div>
                                    <% } %>
                                    <% if (customer.emergency_phone) { %>
                                        <div class="emergency">🚨 <%= customer.emergency_phone %></div>
                                    <% } %>
                                </div>
                            </td>
                            
                            <!-- نوع مشتری -->
                            <td class="type-cell">
                                <% if (customer.customer_type === 'vip') { %>
                                    <span class="type-badge vip">⭐ VIP</span>
                                <% } else if (customer.customer_type === 'wholesale') { %>
                                    <span class="type-badge wholesale">🏢 عمده</span>
                                <% } else if (customer.customer_type === 'regular') { %>
                                    <span class="type-badge regular">🔄 ثابت</span>
                                <% } else { %>
                                    <span class="type-badge normal">👤 عادی</span>
                                <% } %>
                            </td>
                            
                            <!-- سن -->
                            <td class="age-cell">
                                <% if (customer.birth_date) { %>
                                    <% const age = Math.floor((new Date() - new Date(customer.birth_date)) / (365.25 * 24 * 60 * 60 * 1000)) %>
                                    <div class="age-info">
                                        <span class="age"><%= age %> سال</span>
                                        <% if (customer.gender === 'male') { %>
                                            <span class="gender">👨</span>
                                        <% } else if (customer.gender === 'female') { %>
                                            <span class="gender">👩</span>
                                        <% } %>
                                    </div>
                                <% } else { %>
                                    <span class="no-data">-</span>
                                <% } %>
                            </td>
                            
                            <!-- حساب مالی -->
                            <td class="balance-cell">
                                <% if (customer.current_balance > 0) { %>
                                    <div class="balance debt">
                                        <span class="icon">💸</span>
                                        <span class="amount"><%= formatNumber(customer.current_balance) %></span>
                                        <span class="label">بدهکار</span>
                                    </div>
                                <% } else if (customer.current_balance < 0) { %>
                                    <div class="balance credit">
                                        <span class="icon">💰</span>
                                        <span class="amount"><%= formatNumber(Math.abs(customer.current_balance)) %></span>
                                        <span class="label">بستانکار</span>
                                    </div>
                                <% } else { %>
                                    <div class="balance clear">
                                        <span class="icon">✅</span>
                                        <span class="label">تسویه</span>
                                    </div>
                                <% } %>
                            </td>
                            
                            <!-- آخرین خرید -->
                            <td class="purchase-cell">
                                <% if (customer.last_purchase_date) { %>
                                    <% const daysSince = Math.floor((new Date() - new Date(customer.last_purchase_date)) / (24 * 60 * 60 * 1000)) %>
                                    <div class="purchase-info">
                                        <span class="date"><%= moment(customer.last_purchase_date).format('YYYY/MM/DD') %></span>
                                        <% if (daysSince > 90) { %>
                                            <span class="days old">⚠️ <%= daysSince %> روز پیش</span>
                                        <% } else if (daysSince > 30) { %>
                                            <span class="days warning">⏰ <%= daysSince %> روز پیش</span>
                                        <% } else { %>
                                            <span class="days recent">🆕 <%= daysSince %> روز پیش</span>
                                        <% } %>
                                    </div>
                                <% } else { %>
                                    <span class="no-data">-</span>
                                <% } %>
                            </td>
                            
                            <!-- عملیات -->
                            <td class="actions-cell">
                                <div class="action-buttons">
                                    <a href="/customers/view/<%= customer.id %>" class="action-btn view" title="مشاهده جزئیات">
                                        👁️
                                    </a>
                                    <a href="/customers/edit/<%= customer.id %>" class="action-btn edit" title="ویرایش">
                                        ✏️
                                    </a>
                                    <a href="/accounting/customer-detail/<%= customer.id %>" class="action-btn financial" title="حساب مالی">
                                        💰
                                    </a>
                                    <button class="action-btn delete" 
                                            onclick="deleteCustomer(<%= customer.id %>, '<%= customer.full_name %>')"
                                            title="حذف مشتری">
                                        🗑️
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr class="empty-row">
                        <td colspan="9">
                            <div class="empty-state">
                                <div class="empty-icon">😔</div>
                                <div class="empty-title">هیچ مشتری ثبت نشده است</div>
                                <div class="empty-description">برای شروع، اولین مشتری خود را اضافه کنید</div>
                                <a href="/customers/add" class="btn-primary">➕ افزودن مشتری جدید</a>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
/* =================== GLOBAL STYLES =================== */
* {
    box-sizing: border-box;
}

body {
    font-family: 'Vazir', 'Tahoma', sans-serif;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    margin: 0;
    padding: 20px;
    color: #2c3e50;
}

/* =================== HEADER SECTION =================== */
.customers-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    color: white;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
}

.header-text h1 {
    margin: 0 0 10px 0;
    font-size: 2.5em;
    font-weight: bold;
}

.header-text p {
    margin: 0;
    opacity: 0.9;
    font-size: 1.1em;
}

.btn-primary {
    background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%);
    color: #2d3436;
    padding: 15px 25px;
    border-radius: 50px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: bold;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    color: #2d3436;
    text-decoration: none;
}

/* =================== STATISTICS DASHBOARD =================== */
.stats-dashboard {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, #74b9ff, #0984e3);
}

.stat-card.total::before { background: linear-gradient(90deg, #74b9ff, #0984e3); }
.stat-card.active::before { background: linear-gradient(90deg, #00b894, #00a085); }
.stat-card.vip::before { background: linear-gradient(90deg, #fdcb6e, #e17055); }
.stat-card.debtor::before { background: linear-gradient(90deg, #e84393, #fd79a8); }

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}

.stat-icon {
    font-size: 3em;
    line-height: 1;
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-size: 2.5em;
    font-weight: bold;
    margin-bottom: 5px;
    color: #2d3436;
}

.stat-label {
    color: #636e72;
    font-size: 1.1em;
    font-weight: 600;
}

.stat-trend {
    font-size: 1.5em;
    opacity: 0.7;
}

/* =================== SEARCH CONTAINER =================== */
.search-container {
    background: white;
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

.search-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f1f2f6;
}

.search-header h3 {
    margin: 0;
    color: #2d3436;
    font-size: 1.5em;
}

.btn-clear {
    background: linear-gradient(135deg, #ff7675, #e84393);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-clear:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.search-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}

.search-item label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #2d3436;
}

.input-group, .select-group {
    position: relative;
}

.input-group input, .select-group select {
    width: 100%;
    padding: 12px 15px 12px 50px;
    border: 2px solid #ddd;
    border-radius: 10px;
    font-size: 1em;
    transition: all 0.3s ease;
    background: #f8f9fa;
}

.input-group input:focus, .select-group select:focus {
    outline: none;
    border-color: #667eea;
    background: white;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.input-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2em;
    color: #636e72;
    z-index: 2;
}

/* =================== TABLE WRAPPER =================== */
.table-wrapper {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

.table-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 20px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.table-header h3 {
    margin: 0;
    font-size: 1.5em;
}

.table-info {
    background: rgba(255,255,255,0.2);
    padding: 8px 15px;
    border-radius: 20px;
    font-weight: 600;
}

.table-container {
    overflow-x: auto;
}

#customersTable {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95em;
}

#customersTable th {
    background: #2d3436;
    color: white;
    padding: 15px 12px;
    text-align: center;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 10;
}

#customersTable td {
    padding: 15px 12px;
    text-align: center;
    border-bottom: 1px solid #f1f2f6;
    vertical-align: middle;
}

.customer-row {
    transition: all 0.3s ease;
}

.customer-row:hover {
    background: linear-gradient(135deg, #fff9c4 0%, #fcf7e8 100%);
    transform: scale(1.005);
}

/* =================== CELL STYLES =================== */
.status-badges {
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
}

.badge {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.8em;
    font-weight: 600;
    white-space: nowrap;
}

.badge.active { background: #d4edda; color: #155724; }
.badge.inactive { background: #f8d7da; color: #721c24; }
.badge.vip { background: #fff3cd; color: #856404; }

.customer-code {
    font-weight: bold;
    color: #667eea;
    font-size: 1.1em;
}

.customer-info .name {
    font-weight: bold;
    color: #2d3436;
    margin-bottom: 5px;
}

.customer-info .email,
.customer-info .national-id {
    font-size: 0.85em;
    color: #636e72;
    margin-bottom: 3px;
}

.contact-info .phone {
    font-weight: 600;
    color: #00b894;
    margin-bottom: 3px;
}

.contact-info .emergency {
    font-size: 0.85em;
    color: #e84393;
}

.type-badge {
    padding: 6px 12px;
    border-radius: 15px;
    font-weight: 600;
    font-size: 0.85em;
}

.type-badge.vip { background: #fff3cd; color: #856404; }
.type-badge.wholesale { background: #cce7ff; color: #0366d6; }
.type-badge.regular { background: #e7f5ff; color: #0969da; }
.type-badge.normal { background: #f1f2f6; color: #57606a; }

.age-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.age {
    font-weight: 600;
    color: #2d3436;
}

.gender {
    font-size: 1.2em;
}

.balance {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
}

.balance.debt { color: #e84393; }
.balance.credit { color: #00b894; }
.balance.clear { color: #636e72; }

.balance .icon {
    font-size: 1.2em;
}

.balance .amount {
    font-weight: bold;
    font-size: 0.9em;
}

.balance .label {
    font-size: 0.75em;
    opacity: 0.8;
}

.purchase-info .date {
    font-weight: 600;
    color: #2d3436;
    display: block;
    margin-bottom: 3px;
}

.purchase-info .days {
    font-size: 0.8em;
    padding: 2px 6px;
    border-radius: 8px;
}

.days.recent { background: #d4edda; color: #155724; }
.days.warning { background: #fff3cd; color: #856404; }
.days.old { background: #f8d7da; color: #721c24; }

.action-buttons {
    display: flex;
    gap: 8px;
    justify-content: center;
}

.action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 35px;
    height: 35px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
}

.action-btn.view { background: #74b9ff; color: white; }
.action-btn.edit { background: #a29bfe; color: white; }
.action-btn.financial { background: #00b894; color: white; }
.action-btn.delete { background: #ff7675; color: white; }

.action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    color: white;
    text-decoration: none;
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
}

.empty-icon {
    font-size: 4em;
    margin-bottom: 20px;
}

.empty-title {
    font-size: 1.5em;
    font-weight: bold;
    color: #2d3436;
    margin-bottom: 10px;
}

.empty-description {
    color: #636e72;
    margin-bottom: 30px;
}

.no-data {
    color: #bbb;
    font-style: italic;
}

/* =================== RESPONSIVE DESIGN =================== */
@media (max-width: 768px) {
    body {
        padding: 10px;
    }
    
    .customers-header {
        padding: 20px;
        text-align: center;
    }
    
    .header-content {
        flex-direction: column;
    }
    
    .header-text h1 {
        font-size: 2em;
    }
    
    .stats-dashboard {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }
    
    .stat-card {
        padding: 20px;
    }
    
    .stat-number {
        font-size: 2em;
    }
    
    .search-container {
        padding: 20px;
    }
    
    .search-grid {
        grid-template-columns: 1fr;
        gap: 15px;
    }
    
    .search-header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }
    
    .table-header {
        padding: 15px 20px;
        flex-direction: column;
        gap: 10px;
        text-align: center;
    }
    
    #customersTable {
        font-size: 0.8em;
    }
    
    #customersTable th,
    #customersTable td {
        padding: 10px 8px;
    }
    
    .action-buttons {
        flex-direction: column;
        gap: 5px;
    }
    
    .action-btn {
        width: 30px;
        height: 30px;
        font-size: 12px;
    }
}
</style>

<script>
// =================== SEARCH AND FILTER FUNCTIONALITY ===================
document.addEventListener('DOMContentLoaded', function() {
    const nameSearch = document.getElementById('nameSearch');
    const phoneSearch = document.getElementById('phoneSearch');
    const typeFilter = document.getElementById('customerTypeFilter');
    const statusFilter = document.getElementById('statusFilter');
    const tableBody = document.querySelector('#customersTable tbody');
    const tableCount = document.getElementById('tableCount');

    // تابع فیلتر کردن جدول
    function filterTable() {
        const nameValue = nameSearch.value.toLowerCase().trim();
        const phoneValue = phoneSearch.value.toLowerCase().trim();
        const typeValue = typeFilter.value;
        const statusValue = statusFilter.value;
        
        const rows = tableBody.querySelectorAll('.customer-row');
        let visibleCount = 0;

        rows.forEach(row => {
            const nameCell = row.querySelector('.customer-info .name');
            const phoneCell = row.querySelector('.contact-info .phone');
            const type = row.getAttribute('data-type');
            const status = row.getAttribute('data-status');

            let showRow = true;

            // فیلتر نام
            if (nameValue && nameCell) {
                const nameText = nameCell.textContent.toLowerCase();
                if (!nameText.includes(nameValue)) {
                    showRow = false;
                }
            }

            // فیلتر تلفن
            if (phoneValue && phoneCell) {
                const phoneText = phoneCell.textContent.toLowerCase();
                if (!phoneText.includes(phoneValue)) {
                    showRow = false;
                }
            }

            // فیلتر نوع
            if (typeValue && type !== typeValue) {
                showRow = false;
            }

            // فیلتر وضعیت
            if (statusValue && status !== statusValue) {
                showRow = false;
            }

            row.style.display = showRow ? '' : 'none';
            if (showRow) visibleCount++;
        });

        // به‌روزرسانی شمارنده
        tableCount.textContent = visibleCount;
    }

    // Event listeners برای فیلترها
    nameSearch.addEventListener('input', filterTable);
    phoneSearch.addEventListener('input', filterTable);
    typeFilter.addEventListener('change', filterTable);
    statusFilter.addEventListener('change', filterTable);

    // تابع پاک کردن فیلترها
    window.clearAllFilters = function() {
        nameSearch.value = '';
        phoneSearch.value = '';
        typeFilter.value = '';
        statusFilter.value = '';
        filterTable();
        
        // انیمیشن موفقیت
        const clearBtn = document.querySelector('.btn-clear');
        const originalText = clearBtn.innerHTML;
        clearBtn.innerHTML = '✅ پاک شد';
        setTimeout(() => {
            clearBtn.innerHTML = originalText;
        }, 1500);
    };

    // =================== DELETE CUSTOMER FUNCTIONALITY ===================
    window.deleteCustomer = function(customerId, customerName) {
        // نمایش تأیید حذف با طراحی بهتر
        const confirmed = confirm(
            `⚠️ هشدار حذف مشتری\n\n` +
            `آیا مطمئن هستید که می‌خواهید مشتری "${customerName}" را حذف کنید؟\n\n` +
            `🔴 این عمل قابل برگشت نیست!\n` +
            `• تمام سوابق خرید حذف خواهد شد\n` +
            `• اطلاعات مالی پاک خواهد شد\n\n` +
            `برای تأیید روی "OK" کلیک کنید.`
        );

        if (!confirmed) return;

        const deleteBtn = document.querySelector(`[onclick*="${customerId}"]`);
        const originalContent = deleteBtn.innerHTML;
        const row = deleteBtn.closest('.customer-row');

        // انیمیشن لودینگ
        deleteBtn.innerHTML = '⏳';
        deleteBtn.disabled = true;
        row.style.opacity = '0.6';

        fetch(`/customers/delete/${customerId}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // انیمیشن موفقیت
                deleteBtn.innerHTML = '✅';
                row.style.background = 'linear-gradient(135deg, #d4edda, #c3e6cb)';
                
                setTimeout(() => {
                    // حذف ردیف با انیمیشن
                    row.style.transform = 'translateX(-100%)';
                    row.style.opacity = '0';
                    
                    setTimeout(() => {
                        row.remove();
                        filterTable(); // به‌روزرسانی شمارنده
                        
                        // بررسی خالی بودن جدول
                        const remainingRows = tableBody.querySelectorAll('.customer-row');
                        if (remainingRows.length === 0) {
                            tableBody.innerHTML = `
                                <tr class="empty-row">
                                    <td colspan="9">
                                        <div class="empty-state">
                                            <div class="empty-icon">😔</div>
                                            <div class="empty-title">هیچ مشتری ثبت نشده است</div>
                                            <div class="empty-description">برای شروع، اولین مشتری خود را اضافه کنید</div>
                                            <a href="/customers/add" class="btn-primary">➕ افزودن مشتری جدید</a>
                                        </div>
                                    </td>
                                </tr>
                            `;
                        }
                    }, 500);
                }, 1000);

                // نمایش پیام موفقیت
                showNotification('✅ مشتری با موفقیت حذف شد', 'success');
            } else {
                throw new Error(data.message || 'خطا در حذف مشتری');
            }
        })
        .catch(error => {
            console.error('Delete error:', error);
            deleteBtn.innerHTML = originalContent;
            deleteBtn.disabled = false;
            row.style.opacity = '1';
            showNotification('❌ خطا در حذف مشتری: ' + error.message, 'error');
        });
    };

    // =================== NOTIFICATION SYSTEM ===================
    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `notification ${type}`;
        notification.textContent = message;
        
        notification.style.cssText = `
            position: fixed;
            top: 20px;
            right: 20px;
            background: ${type === 'success' ? '#00b894' : '#e84393'};
            color: white;
            padding: 15px 25px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            z-index: 9999;
            font-weight: 600;
            transform: translateX(100%);
            transition: transform 0.3s ease;
        `;

        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.transform = 'translateX(0)';
        }, 100);

        setTimeout(() => {
            notification.style.transform = 'translateX(100%)';
            setTimeout(() => {
                document.body.removeChild(notification);
            }, 300);
        }, 3000);
    }

    // =================== SMOOTH SCROLLING ===================
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });

    // =================== TABLE ENHANCEMENTS ===================
    // افزودن hover effect برای ردیف‌ها
    const tableRows = document.querySelectorAll('.customer-row');
    tableRows.forEach(row => {
        row.addEventListener('mouseenter', function() {
            this.style.transform = 'scale(1.02)';
        });
        
        row.addEventListener('mouseleave', function() {
            this.style.transform = 'scale(1)';
        });
    });
});
</script>

